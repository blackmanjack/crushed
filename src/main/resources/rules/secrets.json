{
  "rules": [
    { "name": "google-api-key", "pattern": "AIza[0-9A-Za-z_-]{20,}" },
    { "name": "aws-access-key", "pattern": "AKIA[0-9A-Z]{12,}" },
    { "name": "jwt", "pattern": "eyJ[A-Za-z0-9_-]+\\.eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]*" },
    { "name": "generic-secret-literal", "pattern": "(?i)(secret|password|api[_-]?key)\\s*[:=]\\s*[\"'][^\"']{6,}[\"']" },
    { "name": "sdk-cred-method", "pattern": "getTempAWSCreds|getJWTToken|getAuthSession" }
  ]
}
